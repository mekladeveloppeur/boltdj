# ==============================
# BoltDjibouti - Configuration
# ==============================
# Copie ce fichier en .env et remplis tes valeurs

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=boltdj
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (change cette valeur en production !)
JWT_SECRET=boltdj_secret_super_securise_2024
JWT_EXPIRES_IN=7d

# SMS (optionnel pour dev - mettre DEMO pour simuler)
SMS_PROVIDER=DEMO
# Pour Twilio:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1234567890

# Google Maps (optionnel pour dev)
GOOGLE_MAPS_API_KEY=DEMO

# Frontend URLs (CORS)
ADMIN_URL=http://localhost:3002
RESTAURANT_URL=http://localhost:3003
CLIENT_URL=http://localhost:3004

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
